# Banco de dados
# Dev local (docker-compose): postgresql+asyncpg://finan:finan@db:5432/finanpessoal
# Railway injeta automaticamente via DATABASE_URL
DATABASE_URL=postgresql+asyncpg://finan:finan@db:5432/finanpessoal

# Evolution API
EVOLUTION_API_URL=https://sua-instancia.evolution.com
EVOLUTION_API_KEY=sua-api-key-aqui
EVOLUTION_INSTANCE=nome-da-instancia

# WhatsApp
# ID do grupo que o bot vai escutar (formato: 5511999999999-1234567890@g.us)
WHATSAPP_GROUP_ID=
# Número do bot para ignorar as próprias mensagens (formato: 5511999999999)
BOT_PHONE_NUMBER=
